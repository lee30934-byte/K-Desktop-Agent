/*
 * Phase 1에서 App.css 끝에 추가할 스타일
 * (tool 메시지 및 stop 버튼용)
 */

.message-tool {
  align-self: stretch;
  background-color: #f3f4f6;
  border: 1px solid #d1d5db;
  color: #374151;
  font-family: "Cascadia Code", "Consolas", monospace;
  font-size: 12px;
  max-width: 100%;
}

.message-tool .message-role {
  color: #6b7280;
}

.composer .stop-btn {
  padding: 0 20px;
  background-color: #ef4444;
  color: #ffffff;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  transition: background-color 0.15s;
}

.composer .stop-btn:hover {
  background-color: #dc2626;
}

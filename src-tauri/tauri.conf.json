{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "K Desktop Agent",
  "version": "0.6.73",
  "identifier": "com.k.desktop-agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "K Desktop Agent",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": true,
        "titleBarStyle": "Transparent",
        "dragDropEnabled": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' ipc: http://ipc.localhost ws://localhost:* https://fonts.googleapis.com https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../sidecar/dist/**/*",
      "../sidecar/node_modules/**/*",
      "../sidecar/package.json",
      "../node-bundle/**/*",
      "../scripts/install-deps.ps1",
      "../scripts/install-kpersonal-mcp.ps1",
      "../scripts/backup.ps1",
      "../scripts/rollback.ps1",
      "../bundled-mcp/server.py",
      "../bundled-mcp/requirements.txt",
      "../bundled-mcp/install.bat",
      "../bundled-mcp/check_config.bat",
      "../bundled-mcp/test_modules.py",
      "../bundled-mcp/README.md",
      "../bundled-mcp/modules/__init__.py",
      "../bundled-mcp/modules/app_launcher.py",
      "../bundled-mcp/modules/computer_control.py",
      "../bundled-mcp/modules/file_manager.py",
      "../bundled-mcp/modules/personal_db.py",
      "../bundled-mcp/modules/uia_control.py",
      "../bundled-mcp/modules/web_automation.py"
    ],
    "externalBin": [],
    "copyright": "",
    "category": "Productivity",
    "shortDescription": "Personal automation agent for Windows",
    "longDescription": "K Desktop Agent: Claude-powered chat that automates your Windows PC via K-Personal MCP.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "ko-KR",
        "upgradeCode": "E8F7D6B5-4A3C-2B1D-9E8F-7A6B5C4D3E2F"
      },
      "nsis": {
        "languages": ["Korean", "English"],
        "displayLanguageSelector": true,
        "installerHooks": "installer-hooks.nsh",
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/lee30934-byte/K-Desktop-Agent/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyMzAyRkFGQzg1RDcwODUKUldTRmNGM0lyeTh3a205UDBrTTdTVHk0ZlFFbG8yVWJRS2M4Nm9abHIvL2dod2FMdHY1L0YrOFMK"
    }
  }
}
